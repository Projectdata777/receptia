# ══════════════════════════════════════════════
# ReceptIA — Variables d'environnement
# Copiez ce fichier en .env et remplissez chaque valeur
# Ne commitez JAMAIS le fichier .env sur GitHub
# ══════════════════════════════════════════════

# ── Stripe ─────────────────────────────────────
# Clé secrète Stripe (tableau de bord → Développeurs → Clés API)
STRIPE_SECRET_KEY=sk_live_...

# Secret du webhook Stripe (tableau de bord → Développeurs → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs Stripe (tableau de bord → Produits → sélectionner le prix → copier l'ID)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Resend ─────────────────────────────────────
# Clé API Resend (resend.com → API Keys)
RESEND_API_KEY=re_...

# Adresse email expéditrice (doit être vérifiée dans Resend)
FROM_EMAIL=contact@receptia.fr

# ── Vapi ───────────────────────────────────────
# ID de votre assistant Vapi (dashboard.vapi.ai → Assistants)
VAPI_ASSISTANT_ID=...

# Clé publique Vapi (dashboard.vapi.ai → Account → Public Key)
VAPI_PUBLIC_KEY=...

# ── Calendly ───────────────────────────────────
# URL complète de votre lien Calendly (ex: https://calendly.com/votre-nom/30min)
CALENDLY_URL=https://calendly.com/VOTRE_LIEN_ICI

# ── Onboarding ─────────────────────────────────
# URL du formulaire Notion/Typeform pour recueillir le script d'accueil client
ONBOARDING_FORM_URL=https://notion.so/VOTRE_FORMULAIRE

# ── Serveur ────────────────────────────────────
PORT=3000
